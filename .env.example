# Database — Render provides this automatically when you link a Postgres instance
DATABASE_URL="postgresql://user:password@localhost:5432/voices"

# Admin password — leave blank to allow open access in local dev
# Set this in the Render dashboard for production
ADMIN_PASSWORD=""

# Upload directory — defaults to ./uploads in local dev
# On Render, set to /data/uploads (matches the persistent disk mount at /data)
UPLOAD_DIR=""

# Optional: public-facing base URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
